---
import Base from '../layouts/Base.astro';
---
<Base
  title="Contact | BenefitsCheck UK"
  description="Contact BenefitsCheck UK. We're an independent website — for personal benefits advice contact Citizens Advice or the relevant DWP helpline."
>
  <div style="max-width:680px;margin:0 auto;padding:4rem 2rem;font-family:'Inter',sans-serif;">
    <a href="/" style="font-size:13px;color:#1a2e1f;font-weight:600;text-decoration:none;">← Back to home</a>
    <h1 style="font-family:'Playfair Display',serif;font-size:2.2rem;color:#1a1a1a;margin:1.5rem 0 1rem;line-height:1.2;">Contact</h1>
    <p style="font-size:15px;color:#333;line-height:1.7;margin-bottom:1rem;">BenefitsCheck UK is an independent website. We don't have a helpline or benefits advisers — for personal benefits advice, please contact Citizens Advice (<a href="https://www.citizensadvice.org.uk" style="color:#1a2e1f;">citizensadvice.org.uk</a>) or call the relevant DWP helpline for your benefit.</p>
    <p style="font-size:15px;color:#333;line-height:1.7;margin-bottom:1rem;">For website feedback or to report an error in our content, email us at: <a href="mailto:hello@benefitscheck.co.uk" style="color:#1a2e1f;">hello@benefitscheck.co.uk</a></p>
  </div>
</Base>
