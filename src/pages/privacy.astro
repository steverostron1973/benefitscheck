---
import Base from '../layouts/Base.astro';
---
<Base
  title="Privacy Policy | BenefitsCheck UK"
  description="BenefitsCheck UK privacy policy. We collect no personal data. All calculations happen in your browser."
>
  <div style="max-width:680px;margin:0 auto;padding:4rem 2rem;font-family:'Inter',sans-serif;">
    <a href="/" style="font-size:13px;color:#1a2e1f;font-weight:600;text-decoration:none;">← Back to checker</a>
    <h1 style="font-family:'Playfair Display',serif;font-size:2.2rem;color:#1a1a1a;margin:1.5rem 0 1rem;line-height:1.2;">Privacy Policy</h1>
    <p style="font-size:15px;color:#333;line-height:1.7;margin-bottom:1rem;">BenefitsCheck UK does not collect, store, or share any personal data. All calculations are performed entirely within your browser. No information you enter is transmitted to any server.</p>
    <p style="font-size:15px;color:#333;line-height:1.7;margin-bottom:1rem;">This site may use Google AdSense to display advertisements. Google may use cookies to serve ads based on your visit to this site. You can opt out of personalised advertising by visiting <a href="https://www.google.com/settings/ads" style="color:#1a2e1f;">Google's Ad Settings</a>.</p>
    <p style="font-size:15px;color:#333;line-height:1.7;margin-bottom:1rem;">This site may use anonymous analytics (such as page view counts) to understand traffic. No personally identifiable information is collected.</p>
    <p style="font-size:13px;color:#888;margin-top:2rem;">Last updated: June 2026</p>
  </div>
</Base>
