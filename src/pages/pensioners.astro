---
import Base from '../layouts/Base.astro';
import PensionChecker from '../components/PensionChecker.jsx';
---
<Base
  title="Pensioner Benefit Checker 2026/27 | BenefitsCheck UK"
  description="Find out what pension benefits you or a loved one are owed in 60 seconds. Free UK checker covering Pension Credit, Attendance Allowance, Warm Home Discount and more. Updated for 2026/27 rates."
>
  <style is:global>
    body { min-height: 100vh; }

    .page {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: stretch;
    }

    /* Left panel */
    .left-panel {
      background: #1a1a2e;
      padding: 2rem 2.5rem;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      position: sticky;
      top: 0;
      height: 100vh;
      overflow: hidden;
    }

    .left-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 1.5rem;
    }

    .left-logo-mark {
      width: 32px;
      height: 32px;
      background: #7c6af5;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
    }

    .left-logo-name {
      font-size: 14px;
      font-weight: 600;
      color: #a8a5d0;
      letter-spacing: 0.04em;
    }

    .left-headline {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 0;
    }

    .left-eyebrow {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #9b8ff7;
      margin-bottom: 0.75rem;
    }

    .left-title {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: clamp(1.8rem, 3vw, 2.4rem);
      color: #fff;
      line-height: 1.2;
      margin-bottom: 0.9rem;
    }

    .left-title em {
      color: #7c6af5;
      font-style: normal;
    }

    .left-title-intro {
      font-size: clamp(1.1rem, 2vw, 1.4rem);
      color: #9b8ff7;
      font-style: normal;
    }

    .left-usps {
      display: flex;
      flex-direction: column;
      gap: 0.9rem;
      margin-bottom: 1rem;
    }

    .left-usp {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
    }

    .left-usp-icon {
      font-size: 1.25rem;
      flex-shrink: 0;
      margin-top: 1px;
    }

    .left-usp-heading {
      font-size: 14px;
      font-weight: 700;
      color: #fff;
      margin-bottom: 3px;
    }

    .left-usp-body {
      font-size: 13px;
      color: #9b9bbf;
      line-height: 1.55;
    }

    .left-stats-label {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #9b8ff7;
      margin-bottom: 0.5rem;
      margin-top: 0;
    }

    .left-stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1px;
      background: #7c6af5;
      border: 1px solid #7c6af5;
      border-radius: 14px;
      overflow: hidden;
      margin-bottom: 1.25rem;
    }

    .left-stat {
      background: #0f0f1f;
      padding: 1rem 1.25rem;
      text-align: center;
    }

    .left-stat-num {
      font-family: 'Playfair Display', serif;
      font-size: 2rem;
      color: #7c6af5;
      line-height: 1;
      margin-bottom: 4px;
    }

    .left-stat-label {
      font-size: 12px;
      color: #c0bedd;
      font-weight: 500;
      line-height: 1.4;
    }

    .left-footer {
      font-size: 12px;
      color: #9b9bbf;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .left-footer::before {
      content: '';
      width: 6px;
      height: 6px;
      background: #7c6af5;
      border-radius: 50%;
      flex-shrink: 0;
    }

    /* Right panel */
    .right-panel {
      background: #f5f4f0;
      padding: 3rem 2.5rem;
      overflow-y: auto;
    }

    .progress-wrap { margin-bottom: 2.25rem; }
    .progress-labels { display: flex; justify-content: space-between; margin-bottom: 8px; }
    .progress-label { font-size: 10px; font-weight: 500; letter-spacing: 0.05em; text-transform: uppercase; color: #888; transition: color 0.3s; }
    .progress-label.active { color: #1a1a2e; }
    .progress-label.done { color: #7c6af5; }
    .progress-track { height: 2px; background: #e0dfd9; border-radius: 999px; }
    .progress-fill { height: 2px; background: #7c6af5; border-radius: 999px; transition: width 0.5s cubic-bezier(0.4,0,0.2,1); }
    .step-title { font-family: 'Playfair Display', serif; font-size: 1.6rem; color: #1a1a1a; margin: 0 0 0.35rem; font-weight: 700; }
    .step-hint { font-size: 14px; color: #333; margin-bottom: 1.75rem; line-height: 1.5; }
    .field { margin-bottom: 1.4rem; }
    .field-label { display: block; font-size: 12px; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; color: #444; margin-bottom: 6px; }
    .field-sublabel { font-size: 13px; color: #444; margin-bottom: 8px; line-height: 1.5; }
    .radio-group { display: flex; flex-direction: column; gap: 8px; }
    .radio-option { display: flex; align-items: center; gap: 12px; padding: 12px 16px; border: 1.5px solid #e0dfd9; border-radius: 10px; cursor: pointer; font-size: 14px; color: #111827; background: #fff; transition: all 0.15s; font-weight: 500; }
    .radio-option:hover { border-color: #c0bfb9; }
    .radio-option.selected { border-color: #1a1a2e; background: #f0eeff; }
    .radio-option input { accent-color: #7c6af5; width: 15px; height: 15px; flex-shrink: 0; cursor: pointer; }
    .text-input, .sel-input { width: 100%; padding: 11px 14px; border: 1.5px solid #e0dfd9; border-radius: 10px; font-size: 14px; font-family: 'Inter', sans-serif; color: #1a1a1a; background: #fff; }
    .text-input:focus, .sel-input:focus { outline: none; border-color: #7c6af5; box-shadow: 0 0 0 3px rgba(124,106,245,0.1); }
    .checkbox-group { display: flex; flex-direction: column; gap: 8px; }
    .checkbox-option { display: flex; align-items: center; gap: 12px; padding: 11px 16px; border: 1.5px solid #e0dfd9; border-radius: 10px; cursor: pointer; font-size: 14px; color: #111; background: #fff; font-weight: 500; }
    .checkbox-option input { accent-color: #7c6af5; width: 15px; height: 15px; flex-shrink: 0; cursor: pointer; }
    .nav { display: flex; justify-content: space-between; align-items: center; margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid #e8e7e2; }
    .nav-right { margin-left: auto; }
    .btn-primary { padding: 11px 24px; background: #1a1a2e; color: #fff; border: none; border-radius: 10px; font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 600; cursor: pointer; transition: opacity 0.15s; }
    .btn-primary:hover { opacity: 0.88; }
    .btn-ghost { padding: 11px 16px; background: transparent; color: #333; border: 1.5px solid #c8c7c0; border-radius: 10px; font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 500; cursor: pointer; }
    .btn-ghost:hover { background: #f0eeff; }

    /* Results */
    .result-banner { background: #1a1a2e; border-radius: 16px; padding: 2.5rem 2rem; text-align: center; margin-bottom: 1.75rem; }
    .result-banner.none { background: #e8e7e2; }
    .result-missing-label { font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: #9b8ff7; margin-bottom: 0.75rem; }
    .result-total { font-family: 'Playfair Display', serif; font-size: clamp(3.5rem, 10vw, 5.5rem); font-weight: 700; color: #7c6af5; line-height: 1; margin-bottom: 0.3rem; letter-spacing: -0.02em; }
    .result-total-sub { font-size: 14px; color: #a8a5d0; font-weight: 500; margin-bottom: 1.75rem; }
    .result-divider { border: none; border-top: 1px solid #2d2d4a; margin: 0 0 1.5rem; }
    .result-count-row { display: flex; align-items: baseline; justify-content: center; gap: 0.6rem; margin-bottom: 0.25rem; }
    .result-count { font-family: 'Playfair Display', serif; font-size: 2rem; color: #fff; line-height: 1; }
    .result-count.none { color: #999; }
    .result-label { font-size: 15px; color: #d4d2f0; font-weight: 500; }
    .result-sublabel { font-size: 12px; color: #7c7aaa; margin-top: 6px; }
    .results-list { display: flex; flex-direction: column; gap: 10px; }
    .result-card { background: #fff; border: 1.5px solid #e0dfd9; border-radius: 12px; padding: 1.25rem 1.4rem; }
    .result-card.likely { border-color: #c5beff; }
    .result-card-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 10px; margin-bottom: 6px; }
    .result-name { font-size: 15px; font-weight: 700; color: #111; }
    .result-amount { font-size: 13px; color: #5a48d4; font-weight: 600; margin-top: 3px; }
    .chip { display: inline-flex; align-items: center; gap: 4px; padding: 4px 12px; border-radius: 999px; font-size: 12px; font-weight: 600; white-space: nowrap; flex-shrink: 0; }
    .chip.yes { background: #ede9ff; color: #5a48d4; }
    .chip.no { background: #e8e7e2; color: #333; }
    .result-summary { font-size: 14px; color: #1a1a1a; line-height: 1.7; margin-bottom: 8px; }
    .result-tip { font-size: 13px; color: #333; line-height: 1.6; margin-bottom: 10px; font-style: italic; }
    .result-link { font-size: 13px; font-weight: 600; color: #1a1a2e; text-decoration: none; border-bottom: 1.5px solid #c5beff; padding-bottom: 1px; }
    .result-link:hover { border-bottom-color: #1a1a2e; }
    .result-link.muted { color: #555; border-bottom-color: #ccc; }
    .unlikely-heading { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: #666; margin: 1.5rem 0 0.6rem; }
    .already-box { margin-top: 1.25rem; padding: 1rem 1.25rem; background: #f5f4f0; border-radius: 10px; border: 1.5px solid #e0dfd9; }
    .already-title { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #555; margin-bottom: 4px; }
    .already-list { font-size: 14px; color: #111; line-height: 1.6; font-weight: 600; }
    .disclaimer { margin-top: 1.5rem; padding: 1rem 1.25rem; background: #eeede8; border-radius: 10px; font-size: 13px; color: #333; line-height: 1.6; }
    .disclaimer strong { color: #111; }
    .footer-note { text-align: center; font-size: 11px; color: #888; margin-top: 1rem; letter-spacing: 0.02em; }

    @media (max-width: 800px) {
      .page { grid-template-columns: 1fr; }
      .left-panel { position: relative; height: auto; padding: 2rem 1.5rem; }
      .left-headline { margin: 1.5rem 0; }
      .right-panel { padding: 2rem 1.25rem; }
    }
  </style>

  <div class="page">
    <div class="left-panel">
      <div class="left-logo">
        <div class="left-logo-mark">£</div>
        <span class="left-logo-name">BenefitsCheck UK</span>
      </div>
      <div class="left-headline">
        <div class="left-eyebrow">For Pensioners & Families · Free · 2026/27 Rates · No sign-up needed</div>
        <h1 class="left-title">
          <span class="left-title-intro">Pensioners —</span><br/>
          Find out what benefits<br/>
          you're owed in<br/>
          <em>60 seconds</em>
        </h1>
        <div class="left-stats-label">The scale of the problem</div>
        <div class="left-stats">
          <div class="left-stat">
            <div class="left-stat-num">800k</div>
            <div class="left-stat-label">pensioners missing out on Pension Credit</div>
          </div>
          <div class="left-stat">
            <div class="left-stat-num">£3,900</div>
            <div class="left-stat-label">average annual Pension Credit entitlement unclaimed</div>
          </div>
        </div>
        <div class="left-usps">
          <div class="left-usp">
            <div class="left-usp-icon">🔒</div>
            <div>
              <div class="left-usp-heading">Your data never leaves your device</div>
              <div class="left-usp-body">All calculations happen in your browser. Nothing is stored, tracked, or shared — ever.</div>
            </div>
          </div>
          <div class="left-usp">
            <div class="left-usp-icon">👨‍👩‍👧</div>
            <div>
              <div class="left-usp-heading">Works for you or a loved one</div>
              <div class="left-usp-body">Check for yourself or on behalf of an elderly parent or relative. Takes 2 minutes.</div>
            </div>
          </div>
          <div class="left-usp">
            <div class="left-usp-icon">💷</div>
            <div>
              <div class="left-usp-heading">9 benefits checked instantly</div>
              <div class="left-usp-body">Including Pension Credit, Attendance Allowance, Warm Home Discount and more.</div>
            </div>
          </div>
        </div>
      </div>
      <div class="left-footer">All calculations happen in your browser. Nothing is stored or shared.</div>
    </div>

    <div class="right-panel">
      <PensionChecker client:load />
      <p class="footer-note" id="footer-note">Pensioner Benefit Checker · 2026/27 · Not financial advice · <a href="/" style="color:#1a1a2e;">BenefitsCheck UK</a></p>
    </div>
  </div>

  <footer style="text-align:center;padding:1.5rem;font-size:12px;color:#888;font-family:'Inter',sans-serif;border-top:1px solid #e0dfd9;background:#f5f4f0;">
    <a href="/" style="color:#1a2e1f;text-decoration:none;margin:0 1rem;">Working Parent Checker</a>
    <a href="/about" style="color:#1a2e1f;text-decoration:none;margin:0 1rem;">About</a>
    <a href="/privacy" style="color:#1a2e1f;text-decoration:none;margin:0 1rem;">Privacy Policy</a>
    <span style="margin:0 1rem;">© 2026 BenefitsCheck UK</span>
  </footer>
</Base>
