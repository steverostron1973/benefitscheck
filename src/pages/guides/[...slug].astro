---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { formatReadingTime } from '../../utils/readingTime';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}

interface Props {
  guide: CollectionEntry<'guides'>;
}

const { guide } = Astro.props;
const { Content } = await guide.render();

const categoryLabels: Record<CollectionEntry<'guides'>['data']['category'], string> = {
  'universal-credit': 'Universal Credit',
  pip: 'PIP',
  'carers-allowance': "Carer's Allowance",
  'council-tax-reduction': 'Council Tax Reduction',
  'housing-benefit': 'Housing Benefit',
  'child-benefit': 'Child Benefit',
  'pension-credit': 'Pension Credit',
  general: 'General',
};

const toolNames: Record<string, string> = {
  '/working-parents/': 'Working Parents',
  '/universal-credit-checker/': 'Universal Credit',
  '/pensioners/': 'Pensioners',
  '/carers/': 'Carers',
  '/carers-allowance-checker/': "Carer's Allowance",
  '/redundancy/': 'Redundancy',
  '/self-employed/': 'Self-Employed',
  '/new-parent/': 'New Parents',
  '/disabled/': 'Sick or Disabled Workers',
};

function formatDate(date: Date) {
  return date.toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}

function toolNameFromPath(path: string) {
  const normalized = path.endsWith('/') ? path : `${path}/`;
  if (toolNames[normalized]) return toolNames[normalized];

  const slug = normalized.replace(/^\/|\/$/g, '');
  return slug
    .split('-')
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
}

const categoryLabel = categoryLabels[guide.data.category];
const toolName = toolNameFromPath(guide.data.relatedTool);
const pageTitle = `${guide.data.title} | BenefitsCheck.co.uk`;
const readingTime = formatReadingTime(guide.body);
---

<Base showHeader title={pageTitle} description={guide.data.description}>

  <style is:global>
    body { background: #f5f4f0; }

    .guide-page {
      max-width: 720px;
      margin: 0 auto;
      padding: 2.5rem 2rem 4rem;
    }

    .breadcrumb {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.35rem 0.5rem;
      font-size: 13px;
      color: #888;
      margin-bottom: 1.75rem;
      line-height: 1.5;
    }

    .breadcrumb a {
      color: #0d1f3c;
      font-weight: 600;
      text-decoration: none;
    }

    .breadcrumb a:hover {
      color: #c8102e;
    }

    .breadcrumb-sep {
      color: #bbb;
    }

    .breadcrumb-current {
      color: #555;
    }

    .guide-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.9rem, 4vw, 2.5rem);
      color: #0d1f3c;
      line-height: 1.2;
      margin-bottom: 0.75rem;
    }

    .guide-meta {
      font-size: 13px;
      color: #888;
      margin-bottom: 2.25rem;
      line-height: 1.6;
    }

    .guide-meta-sep {
      margin: 0 0.4rem;
    }

    .guide-content {
      font-size: 15px;
      color: #333;
      line-height: 1.75;
    }

    .guide-content :global(h2) {
      font-family: 'Playfair Display', serif;
      font-size: 1.35rem;
      color: #0d1f3c;
      margin: 2rem 0 0.75rem;
      line-height: 1.3;
    }

    .guide-content :global(h3) {
      font-size: 1.1rem;
      font-weight: 700;
      color: #1a1a1a;
      margin: 1.5rem 0 0.5rem;
    }

    .guide-content :global(p) {
      margin-bottom: 1rem;
    }

    .guide-content :global(ul),
    .guide-content :global(ol) {
      margin: 0 0 1rem 1.25rem;
    }

    .guide-content :global(li) {
      margin-bottom: 0.35rem;
    }

    .guide-content :global(a) {
      color: #0d1f3c;
      font-weight: 600;
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .guide-content :global(a:hover) {
      color: #c8102e;
    }

    .guide-cta {
      margin-top: 2.5rem;
      background: #0d1f3c;
      border-radius: 16px;
      padding: 2rem 2.25rem;
      border-top: 4px solid #c8102e;
    }

    .guide-cta-text {
      font-family: 'Playfair Display', serif;
      font-size: 1.35rem;
      color: #fff;
      line-height: 1.35;
      margin-bottom: 1.25rem;
    }

    .guide-cta-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 11px 22px;
      background: #c8102e;
      color: #fff;
      border-radius: 10px;
      font-size: 14px;
      font-weight: 600;
      text-decoration: none;
      transition: background 0.15s;
    }

    .guide-cta-btn:hover {
      background: #e8192e;
    }

    @media (max-width: 600px) {
      .guide-page {
        padding: 2rem 1.25rem 3rem;
      }

      .guide-cta {
        padding: 1.5rem 1.25rem;
      }
    }
  </style>

  <article class="guide-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="breadcrumb-sep">›</span>
      <a href="/guides/">Guides</a>
      <span class="breadcrumb-sep">›</span>
      <span class="breadcrumb-current">{categoryLabel}</span>
      <span class="breadcrumb-sep">›</span>
      <span class="breadcrumb-current">{guide.data.title}</span>
    </nav>

    <h1 class="guide-title">{guide.data.title}</h1>

    <p class="guide-meta">
      Published {formatDate(guide.data.publishDate)}
      {guide.data.updatedDate && (
        <>
          <span class="guide-meta-sep">·</span>
          Updated {formatDate(guide.data.updatedDate)}
        </>
      )}
      <span class="guide-meta-sep">·</span>
      {readingTime}
    </p>

    <div class="guide-content">
      <Content />
    </div>

    <aside class="guide-cta">
      <p class="guide-cta-text">
        Check if you're eligible — use our free {toolName} checker
      </p>
      <a href={guide.data.relatedTool} class="guide-cta-btn">
        Start check →
      </a>
    </aside>
  </article>
</Base>
