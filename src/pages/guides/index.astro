---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import GuideCard from '../../components/GuideCard.astro';
import { categoryLabels } from '../../data/guideCategories';

const guides = (await getCollection('guides')).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
---

<Base
  title="Benefits Guides | BenefitsCheck.co.uk"
  description="Free, plain-English guides to UK benefits — Universal Credit, PIP, Carer's Allowance, Pension Credit and more. Written to help you understand what you're entitled to."
>
  <Header />

  <style is:global>
    body { background: #dcdbd6; }

    .guides-page {
      max-width: 1060px;
      margin: 0 auto;
      padding: 3.5rem 2rem 4.5rem;
    }

    .guides-eyebrow {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #c8102e;
      margin-bottom: 0.5rem;
    }

    .guides-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 3vw, 2.4rem);
      color: #0d1f3c;
      margin-bottom: 0.75rem;
      line-height: 1.2;
    }

    .guides-subtitle {
      font-size: 15px;
      color: #555;
      line-height: 1.65;
      max-width: 620px;
      margin-bottom: 2rem;
    }

    .category-filters {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 2.5rem;
    }

    .category-filter {
      font-size: 12px;
      font-weight: 600;
      color: #0d1f3c;
      background: #fff;
      border: 1.5px solid #d0cfc9;
      border-radius: 999px;
      padding: 6px 14px;
      text-decoration: none;
      transition: all 0.15s;
    }

    .category-filter:hover {
      border-color: #0d1f3c;
      background: #f5f4f0;
    }

    .guide-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.25rem;
      align-items: stretch;
    }

    .guides-empty {
      font-size: 15px;
      color: #555;
      line-height: 1.65;
    }

    @media (max-width: 600px) {
      .guides-page {
        padding: 2.5rem 1.25rem 3.5rem;
      }
    }
  </style>

  <div class="guides-page">
    <p class="guides-eyebrow">Free UK benefit guides</p>
    <h1 class="guides-title">Benefits Guides</h1>
    <p class="guides-subtitle">
      Plain-English guides to help you understand UK benefits — who qualifies, how to claim, and what to watch out for.
    </p>

    <nav class="category-filters" aria-label="Browse by category">
      {Object.entries(categoryLabels).map(([slug, label]) => (
        <a href={`/guides/${slug}/`} class="category-filter">{label}</a>
      ))}
    </nav>

    {guides.length === 0 ? (
      <p class="guides-empty">No guides published yet. Check back soon.</p>
    ) : (
      <div class="guide-grid">
        {guides.map((guide) => (
          <GuideCard guide={guide} />
        ))}
      </div>
    )}
  </div>
</Base>
