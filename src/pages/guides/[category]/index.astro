---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import GuideCard from '../../../components/GuideCard.astro';
import {
  guideCategories,
  categoryLabels,
  categoryIntros,
  type GuideCategory,
} from '../../../data/guideCategories';

export async function getStaticPaths() {
  const allGuides = await getCollection('guides');

  return guideCategories.map((category) => ({
    params: { category },
    props: {
      category,
      guides: allGuides
        .filter((guide) => guide.data.category === category)
        .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()),
    },
  }));
}

interface Props {
  category: GuideCategory;
  guides: CollectionEntry<'guides'>[];
}

const { category, guides } = Astro.props;
const categoryLabel = categoryLabels[category];
const pageTitle = `${categoryLabel} Guides | BenefitsCheck.co.uk`;
---

<Base
  showHeader
  title={pageTitle}
  description={categoryIntros[category]}
>

  <style is:global>
    body { background: #dcdbd6; }

    .guides-page {
      max-width: 1060px;
      margin: 0 auto;
      padding: 3.5rem 2rem 4.5rem;
    }

    .guides-breadcrumb {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.35rem 0.5rem;
      font-size: 13px;
      color: #888;
      margin-bottom: 1.5rem;
      line-height: 1.5;
    }

    .guides-breadcrumb a {
      color: #0d1f3c;
      font-weight: 600;
      text-decoration: none;
    }

    .guides-breadcrumb a:hover {
      color: #c8102e;
    }

    .guides-breadcrumb-sep {
      color: #bbb;
    }

    .guides-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.8rem, 3vw, 2.4rem);
      color: #0d1f3c;
      margin-bottom: 0.75rem;
      line-height: 1.2;
    }

    .guides-subtitle {
      font-size: 15px;
      color: #555;
      line-height: 1.65;
      max-width: 620px;
      margin-bottom: 2.5rem;
    }

    .guide-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.25rem;
      align-items: stretch;
    }

    .guides-empty {
      font-size: 15px;
      color: #555;
      line-height: 1.65;
    }

    .pip2-banner {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 1rem 1.5rem;
      margin: 0 0 2rem;
      padding: 1.25rem 1.4rem;
      background: #0d1f3c;
      border-radius: 14px;
      border-top: 4px solid #c8102e;
      color: #fff;
    }

    .pip2-banner-copy {
      flex: 1 1 240px;
    }

    .pip2-banner-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #c8102e;
      margin-bottom: 0.35rem;
    }

    .pip2-banner-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.25rem;
      line-height: 1.3;
      margin-bottom: 0.35rem;
    }

    .pip2-banner-text {
      font-size: 14px;
      color: #a8c0d8;
      line-height: 1.5;
    }

    .pip2-banner-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 11px 18px;
      background: #c8102e;
      color: #fff;
      border-radius: 10px;
      font-size: 14px;
      font-weight: 600;
      text-decoration: none;
      white-space: nowrap;
      transition: background 0.15s;
    }

    .pip2-banner-btn:hover {
      background: #e8192e;
    }

    @media (max-width: 600px) {
      .guides-page {
        padding: 2.5rem 1.25rem 3.5rem;
      }
    }
  </style>

  <div class="guides-page">
    <nav class="guides-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="guides-breadcrumb-sep">›</span>
      <a href="/guides/">Guides</a>
      <span class="guides-breadcrumb-sep">›</span>
      <span>{categoryLabel}</span>
    </nav>

    <h1 class="guides-title">{categoryLabel} Guides</h1>
    <p class="guides-subtitle">{categoryIntros[category]}</p>

    {category === 'pip' && (
      <aside class="pip2-banner" aria-label="PIP2 form guide">
        <div class="pip2-banner-copy">
          <p class="pip2-banner-label">Interactive walkthrough</p>
          <p class="pip2-banner-title">PIP2 Form Guide</p>
          <p class="pip2-banner-text">
            Step-by-step help answering every “How your disability affects you” activity — Daily Living and Mobility.
          </p>
        </div>
        <a href="/guides/pip2-form-guide/" class="pip2-banner-btn">Open PIP2 Guide →</a>
      </aside>
    )}

    {guides.length === 0 ? (
      <p class="guides-empty">No {categoryLabel.toLowerCase()} guides published yet. <a href="/guides/">Browse all guides</a>.</p>
    ) : (
      <div class="guide-grid">
        {guides.map((guide) => (
          <GuideCard guide={guide} />
        ))}
      </div>
    )}
  </div>
</Base>
