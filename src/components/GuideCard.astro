---
import type { CollectionEntry } from 'astro:content';
import { categoryLabels } from '../data/guideCategories';
import { formatReadingTime } from '../utils/readingTime';

interface Props {
  guide: CollectionEntry<'guides'>;
}

const { guide } = Astro.props;
const readingTime = formatReadingTime(guide.body);
---

<a href={`/guides/${guide.slug}/`} class="guide-card">
  <span class="guide-card-badge">{categoryLabels[guide.data.category]}</span>
  <h2 class="guide-card-title">{guide.data.title}</h2>
  <p class="guide-card-desc">{guide.data.description}</p>
  <div class="guide-card-footer">
    <span class="guide-card-reading-time">{readingTime}</span>
    <span class="guide-card-btn">Read guide →</span>
  </div>
</a>

<style>
  .guide-card {
    background: #fff;
    border: 2px solid #d0cfc9;
    border-radius: 16px;
    padding: 2rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    cursor: pointer;
    min-height: 100%;
  }

  .guide-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: #0d1f3c;
    transition: background 0.2s;
  }

  .guide-card:hover {
    border-color: #0d1f3c;
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(13, 31, 60, 0.14);
  }

  .guide-card:hover::before {
    background: #c8102e;
  }

  .guide-card:hover .guide-card-title {
    color: #c8102e;
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 2px;
  }

  .guide-card:hover .guide-card-btn {
    background: #c8102e;
  }

  .guide-card-badge {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 4px;
    background: #0d1f3c;
    color: #fff;
  }

  .guide-card-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.45rem;
    color: #0d1f3c;
    margin-bottom: 0.75rem;
    line-height: 1.25;
    padding-right: 5rem;
    transition: color 0.15s, text-decoration 0.15s;
  }

  .guide-card-desc {
    font-size: 13px;
    color: #555;
    line-height: 1.65;
    flex: 1;
    margin-bottom: 1.5rem;
  }

  .guide-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: auto;
    padding-top: 1.25rem;
    border-top: 1px solid #e8e7e2;
  }

  .guide-card-reading-time {
    font-size: 12px;
    color: #888;
    font-weight: 500;
    flex-shrink: 0;
  }

  .guide-card-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 11px 22px;
    background: #0d1f3c;
    color: #fff;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s;
    margin-left: auto;
    flex-shrink: 0;
  }
</style>
