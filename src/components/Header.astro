---
const currentPath = Astro.url.pathname;

const checkers = [
  { label: 'Universal Credit', href: '/universal-credit-checker' },
  { label: 'Working Parents', href: '/working-parents' },
  { label: 'Pensioners', href: '/pensioners' },
  { label: 'Carers', href: '/carers' },
  { label: 'Recently Redundant', href: '/redundancy' },
  { label: 'Self-Employed', href: '/self-employed' },
  { label: 'New Parents', href: '/new-parent' },
  { label: 'Sick or Disabled Workers', href: '/disabled' },
];

const isCheckerActive = checkers.some(
  (checker) => currentPath === checker.href || currentPath.startsWith(`${checker.href}/`)
);

const isGuidesActive =
  currentPath === '/guides' ||
  currentPath === '/guides/' ||
  currentPath.startsWith('/guides/');
---

<style is:global>
  :root {
    --site-header-height: 68px;
  }

  .nav {
    background: #0d1f3c;
    padding: 0 2.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    width: 100%;
    height: var(--site-header-height);
    box-sizing: border-box;
    z-index: 100;
    border-bottom: 3px solid #c8102e;
  }
  .nav-logo { display: flex; align-items: center; gap: 12px; text-decoration: none; }
  .nav-logo-mark { width: 38px; height: 38px; background: #c8102e; border-radius: 9px; display: flex; align-items: center; justify-content: center; font-size: 20px; color: #fff; font-weight: 900; font-family: 'Playfair Display', serif; }
  .nav-logo-text { display: flex; flex-direction: column; }
  .nav-logo-name { font-size: 16px; font-weight: 700; color: #fff; letter-spacing: -0.01em; line-height: 1.1; }
  .nav-logo-tagline { font-size: 10px; color: #7a9ec0; font-weight: 500; letter-spacing: 0.05em; text-transform: uppercase; }
  .nav-links { display: flex; align-items: center; gap: 0.25rem; }
  .nav-link { font-size: 13px; font-weight: 500; color: #a8c0d8; text-decoration: none; padding: 6px 14px; border-radius: 8px; transition: all 0.15s; }
  .nav-link:hover { color: #fff; background: rgba(255,255,255,0.08); }
  .nav-link.active { color: #fff; font-weight: 600; }

  .nav-dropdown { position: relative; }
  .nav-dropdown-toggle { display: inline-block; cursor: default; user-select: none; }
  .nav-dropdown-menu {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    min-width: 240px;
    background: #132a4d;
    border: 1px solid #2a4a70;
    border-radius: 10px;
    padding: 0.4rem 0;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.35);
    opacity: 0;
    visibility: hidden;
    transform: translateY(6px);
    transition: opacity 0.15s, visibility 0.15s, transform 0.15s;
    z-index: 200;
  }
  .nav-dropdown-menu::before {
    content: '';
    position: absolute;
    top: -8px;
    left: 0;
    right: 0;
    height: 8px;
  }
  .nav-dropdown:hover .nav-dropdown-menu,
  .nav-dropdown:focus-within .nav-dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .nav-dropdown:hover .nav-dropdown-toggle,
  .nav-dropdown:focus-within .nav-dropdown-toggle {
    color: #fff;
    background: rgba(255, 255, 255, 0.08);
  }
  .nav-dropdown-item {
    display: block;
    font-size: 13px;
    font-weight: 500;
    color: #c8d8ea;
    text-decoration: none;
    padding: 8px 16px;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .nav-dropdown-item:hover,
  .nav-dropdown-item.active {
    color: #fff;
    background: rgba(255, 255, 255, 0.1);
  }

  @media (max-width: 700px) {
    .nav { padding: 0 1.25rem; }
    .nav-links { display: none; }
  }
</style>

<nav class="nav">
  <a href="/" class="nav-logo">
    <div class="nav-logo-mark">£</div>
    <div class="nav-logo-text">
      <span class="nav-logo-name">BenefitsCheck UK</span>
      <span class="nav-logo-tagline">Free · Independent · 2026/27 Rates</span>
    </div>
  </a>
  <div class="nav-links">
    <a href="/" class:list={['nav-link', { active: currentPath === '/' }]}>Home</a>
    <div class="nav-dropdown">
      <span class:list={['nav-link', 'nav-dropdown-toggle', { active: isCheckerActive }]}>Checkers ▾</span>
      <div class="nav-dropdown-menu">
        {checkers.map((checker) => (
          <a
            href={checker.href}
            class:list={['nav-dropdown-item', { active: currentPath === checker.href }]}
          >
            {checker.label}
          </a>
        ))}
      </div>
    </div>
    <a href="/guides/" class:list={['nav-link', { active: isGuidesActive }]}>Guides</a>
    <a href="/about" class:list={['nav-link', { active: currentPath === '/about' }]}>About</a>
  </div>
</nav>
